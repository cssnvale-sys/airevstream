  "infrastructure": {
    "docker_compose_file": "docker-compose.yml",
    "services": [
      {
        "name": "postgres",
        "image": "postgres:16-alpine",
        "container_name": "airevstream-postgres",
        "ports": ["5432:5432"],
        "volumes": ["postgres_data:/var/lib/postgresql/data"],
        "healthcheck": true
      },
      {
        "name": "redis",
        "image": "redis:7-alpine",
        "container_name": "airevstream-redis",
        "ports": ["6379:6379"],
        "volumes": ["redis_data:/data"],
        "healthcheck": true
      },
      {
        "name": "minio",
        "image": "minio/minio:latest",
        "container_name": "airevstream-minio",
        "ports": ["9000:9000", "9001:9001"],
        "volumes": ["minio_data:/data"],
        "healthcheck": true
      }
    ],
    "named_volumes": ["postgres_data", "redis_data", "minio_data"]
  },
