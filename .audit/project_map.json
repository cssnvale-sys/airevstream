      "job_types": ["seasoning:enroll", "seasoning:signup", "seasoning:warm", "seasoning:check-due", "seasoning:graduate"]
    }
  },

  "cron_repeatable_jobs": [
    {
      "name": "posting:check-scheduled",
      "worker": "posting.worker.ts",
      "interval": "every 60 seconds",
      "description": "Check for posts that need to be published"
    },
    {
      "name": "maintenance:cleanup",
      "worker": "maintenance.worker.ts",
      "interval": "every 24 hours",
      "description": "Clean up old data"
    },
    {
      "name": "maintenance:backup",
      "worker": "maintenance.worker.ts",
      "interval": "every 7 days",
      "description": "Backup database/storage"
    },
    {
      "name": "maintenance:metrics",
      "worker": "maintenance.worker.ts",
      "interval": "every 5 minutes",
      "description": "Collect system metrics"
    },
    {
      "name": "research:trends",
      "worker": "research.worker.ts",
      "interval": "every 12 hours",
      "description": "Discover trending topics across platforms"
    },
    {
      "name": "seasoning:check-due",
      "worker": "account.worker.ts",
      "interval": "every 15 minutes",
      "description": "Scan enrollments for due seasoning activities"
    }
  ],

  "flow_pipelines": {
    "content_pipeline": {
      "function": "startContentPipeline",
      "file": "packages/queue/src/flows.ts",
      "steps": [
        "1. research:populate-knowledge (leaf)",
        "2. content:generate (depends on research)",
        "3. production:generate-storyboard (root)"
      ]
    },
    "cinema_pipeline": {
      "function": "startCinemaPipeline",
      "file": "packages/queue/src/flows.ts",
      "steps": [
        "1. research:populate-knowledge (leaf — runs first)",
        "2. content:generate (depends on research)",
        "3. production:generate-storyboard (depends on script)",
        "4. production:generate-shots (depends on storyboard)",
        "5. production:qc-gate (depends on shots)",
        "6. production:mix-audio (depends on QC pass)",
        "7. production:render-video (depends on audio + approved shots)",
        "8. content:final-review (depends on rendered video — ROOT)"
      ]
    },
    "seasoning_pipeline": {
      "function": "startSeasoningPipeline",
      "file": "packages/queue/src/flows.ts",
      "steps": [
        "Queues seasoning:enroll jobs per account+platform with staggered delays"
      ]
    }
  },

