# ─── AiRevStream .env (development) ───
# Copy to `.env` and fill in every REQUIRED value before `make bootstrap`.
# Run `make doctor` to verify your setup at any time.

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://airevstream:airevstream_dev@localhost:5432/airevstream

# ── Redis ────────────────────────────────────────────────────────────────
# Host port 6389 → container 6379, so we don't clash with a system-wide
# Homebrew `redis-server` on 6379.
REDIS_URL=redis://localhost:6389

# ── MinIO (S3-compatible object storage) ────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=airevstream
MINIO_SECRET_KEY=airevstream_dev_secret_key_change_me
MINIO_USE_SSL=false

# ── Encryption (REQUIRED) ───────────────────────────────────────────────
# Used to encrypt stored API tokens. Must be a 64-character hex string.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ── JWT (REQUIRED) ──────────────────────────────────────────────────────
# Used to sign session tokens. Each must be ≥ 32 chars.
# Generate each with: openssl rand -hex 64
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Ollama (local LLM) ──────────────────────────────────────────────────
# Start Ollama separately: `ollama serve` (or install the desktop app).
# OLLAMA_DEFAULT_MODEL overrides the built-in fallback of `qwen3:8b`.
# Set this to whichever tag you've pulled (e.g. `qwen3.5:122b`, `llama3.1:8b`).
# Check what's installed with: `curl -s localhost:11434/api/tags | jq '.models[].name'`.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:8b

# ── ComfyUI (image generation) ──────────────────────────────────────────
COMFYUI_URL=http://localhost:8188
COMFYUI_TIMEOUT_MS=120000

# ── CORS + URLs ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Service ports ───────────────────────────────────────────────────────
# WORKFLOW_ENGINE_PORT defaults to 3011 (not 3001) to avoid colliding with
# mission-control / openclaw dashboards that also listen on 3001 by default.
NODE_ENV=development
WEB_PORT=3000
WORKFLOW_ENGINE_PORT=3011
PRODUCTION_PIPELINE_PORT=3002
AI_ASSISTANT_PORT=3003

# ── Registration (set 'true' to disable new signups) ────────────────────
REGISTRATION_DISABLED=false

# ── Platform API credentials (optional — required only to publish) ──────
# OPENAI_API_KEY=
# YOUTUBE_API_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# INSTAGRAM_API_VERSION=v18.0
# FACEBOOK_API_VERSION=v18.0

# ── Text-to-Speech (optional) ───────────────────────────────────────────
# TTS_BASE_URL=http://localhost:5500
# TTS_API_KEY=

# ── Signup automation (optional — only needed for seasoning pipeline) ───
# CAPTCHA_SOLVER_API_KEY=        # 2Captcha key (KI-063)
# SMS_VERIFIER_API_KEY=          # sms-activate.org key (KI-063)
