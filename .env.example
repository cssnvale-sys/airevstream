# Database
DATABASE_URL=postgresql://airevstream:airevstream_dev@localhost:5432/airevstream

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=airevstream
MINIO_SECRET_KEY=airevstream_dev_secret_key_change_me

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# ComfyUI
COMFYUI_URL=http://localhost:8188
COMFYUI_TIMEOUT_MS=120000

# Platform API versions (optional overrides)
# INSTAGRAM_API_VERSION=v18.0
# FACEBOOK_API_VERSION=v18.0

# Text-to-Speech (Piper or ElevenLabs)
# TTS_BASE_URL=http://localhost:5500
# TTS_API_KEY=

# CORS allowed origins (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000

# Frontend URL (used in password reset emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Registration (set to 'true' to disable open registration in production)
# REGISTRATION_DISABLED=false
