# ─── AiRevStream Production Environment ───
# Copy to .env and fill in all values

# ─── Database ───
DATABASE_URL=postgresql://airevstream:CHANGE_ME@postgres:5432/airevstream

# ─── Redis ───
REDIS_URL=redis://redis:6379

# ─── JWT ───
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_64_byte_hex_string

# ─── Encryption ───
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_generate_a_32_byte_hex_string

# ─── MinIO / S3 Storage ───
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_USE_SSL=false

# ─── AI Services ───
# Ollama (local LLM)
OLLAMA_URL=http://ollama:11434

# ComfyUI (image generation)
COMFYUI_URL=http://comfyui:8188
COMFYUI_TIMEOUT_MS=120000

# ─── Service Ports ───
WEB_PORT=3000
WORKFLOW_ENGINE_PORT=3001
PRODUCTION_PIPELINE_PORT=3002
AI_ASSISTANT_PORT=3003

# ─── Environment ───
NODE_ENV=production
