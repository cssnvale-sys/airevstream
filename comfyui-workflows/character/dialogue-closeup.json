{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{model|sd_xl_base_1.0.safetensors}}"
    },
    "_meta": {
      "title": "Load SDXL Checkpoint"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive_prompt|cinematic close-up portrait, 85mm lens, shallow depth of field, bokeh background, expressive face, studio lighting, film grain, high detail, sharp focus on eyes}}",
      "clip": ["1", 1]
    },
    "_meta": {
      "title": "CLIP Text Encode (Positive)"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt|blurry, low quality, watermark, text, deformed, disfigured, bad anatomy, extra limbs, noisy, jpeg artifacts, full body, wide shot, multiple people}}",
      "clip": ["1", 1]
    },
    "_meta": {
      "title": "CLIP Text Encode (Negative)"
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    },
    "_meta": {
      "title": "Empty Latent Image (1024x1024)"
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "seed": "{{seed|0}}",
      "steps": 30,
      "cfg": 7.5,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    },
    "_meta": {
      "title": "KSampler"
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    },
    "_meta": {
      "title": "VAE Decode"
    }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["6", 0],
      "filename_prefix": "{{filename_prefix|dialogue_closeup}}"
    },
    "_meta": {
      "title": "Save Image"
    }
  }
}
