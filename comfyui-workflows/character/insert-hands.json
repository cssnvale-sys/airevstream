{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{model|sd_xl_base_1.0.safetensors}}"
    },
    "_meta": {
      "title": "Load SDXL Checkpoint"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive_prompt|extreme close-up macro shot, hands detail, product insert, shallow depth of field, studio lighting, sharp focus, high detail texture, cinematic, 4k quality}}",
      "clip": ["1", 1]
    },
    "_meta": {
      "title": "CLIP Text Encode (Positive)"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt|blurry, low quality, watermark, text, deformed hands, extra fingers, bad anatomy, noisy, jpeg artifacts, wide shot, full body}}",
      "clip": ["1", 1]
    },
    "_meta": {
      "title": "CLIP Text Encode (Negative)"
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 768,
      "height": 768,
      "batch_size": 1
    },
    "_meta": {
      "title": "Empty Latent Image (768x768)"
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "seed": "{{seed|0}}",
      "steps": 30,
      "cfg": 7.5,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    },
    "_meta": {
      "title": "KSampler"
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    },
    "_meta": {
      "title": "VAE Decode"
    }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["6", 0],
      "filename_prefix": "{{filename_prefix|insert_hands}}"
    },
    "_meta": {
      "title": "Save Image"
    }
  }
}
