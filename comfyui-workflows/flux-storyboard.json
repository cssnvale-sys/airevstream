{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{model|flux1-schnell-fp8.safetensors}}"
    },
    "_meta": {
      "title": "Load FLUX schnell FP8 Checkpoint"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive_prompt|A cinematic video frame, film still, 16:9 widescreen composition, professional cinematography, detailed scene, movie-quality lighting, sharp focus}}",
      "clip": ["1", 1]
    },
    "_meta": {
      "title": "CLIP Text Encode (Positive)"
    }
  },
  "3": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width": 1280,
      "height": 720,
      "batch_size": 1
    },
    "_meta": {
      "title": "Empty Latent Image (1280x720 Video Frame)"
    }
  },
  "4": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["2", 0],
      "latent_image": ["3", 0],
      "seed": "{{seed|0}}",
      "steps": 4,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0
    },
    "_meta": {
      "title": "KSampler (FLUX schnell — 4 steps, CFG 1.0)"
    }
  },
  "5": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["4", 0],
      "vae": ["1", 2]
    },
    "_meta": {
      "title": "VAE Decode"
    }
  },
  "6": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["5", 0],
      "filename_prefix": "{{filename_prefix|flux_storyboard}}"
    },
    "_meta": {
      "title": "Save Image"
    }
  }
}