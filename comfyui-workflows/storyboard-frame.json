{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "{{model|sd_xl_base_1.0.safetensors}}"
    },
    "_meta": {
      "title": "Load SDXL Checkpoint"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{positive_prompt|A cinematic video frame, film still, 16:9 widescreen composition, professional cinematography, detailed scene, movie-quality lighting, sharp focus}}",
      "clip": ["1", 1]
    },
    "_meta": {
      "title": "CLIP Text Encode (Positive)"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "{{negative_prompt|blurry, low quality, watermark, text, logo, ugly, deformed, disfigured, bad anatomy, extra limbs, jpeg artifacts, oversaturated, letterboxed, pillarboxed, border, frame}}",
      "clip": ["1", 1]
    },
    "_meta": {
      "title": "CLIP Text Encode (Negative)"
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": 1280,
      "height": 720,
      "batch_size": 1
    },
    "_meta": {
      "title": "Empty Latent Image (1280x720 Video Frame)"
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "seed": "{{seed|0}}",
      "steps": 25,
      "cfg": 7.0,
      "sampler_name": "euler_ancestral",
      "scheduler": "normal",
      "denoise": 1.0
    },
    "_meta": {
      "title": "KSampler"
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    },
    "_meta": {
      "title": "VAE Decode"
    }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["6", 0],
      "filename_prefix": "{{filename_prefix|storyboard}}"
    },
    "_meta": {
      "title": "Save Image"
    }
  }
}