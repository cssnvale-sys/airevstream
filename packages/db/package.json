{
  "name": "@airevstream/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/jwt": "10.0.0",
    "@prisma/client": "^6.19.3",
    "next": "16.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
