model WorkflowJob {
  id             String   @id @default(uuid()) @db.Uuid
  jobType        String   @map("job_type") @db.VarChar(50) // content_production, account_creation, warming, research, posting
  priority       Int      @default(5) // 1=highest, 10=lowest

  // Context
  channelId      String?  @map("channel_id") @db.Uuid
  contentId      String?  @map("content_id") @db.Uuid
  emailAccountId String?  @map("email_account_id") @db.Uuid

  // Execution
  status         String   @default("queued") @db.VarChar(20) // queued, running, paused, completed, failed, cancelled
  progress       Int      @default(0) // 0-100
  etaSec         Int?     @map("eta_sec")

  // Config
  params         Json     @default("{}") @db.JsonB
  result         Json     @default("{}") @db.JsonB
  error          String?
  retryCount     Int      @default(0) @map("retry_count")
  maxRetries     Int      @default(3) @map("max_retries")

  // HITL
  needsHuman     Boolean  @default(false) @map("needs_human")
  humanTaskDesc  String?  @map("human_task_desc")
  humanLinks     Json     @default("[]") @map("human_links") @db.JsonB
  humanCompletedAt DateTime? @map("human_completed_at") @db.Timestamptz

  startedAt      DateTime? @map("started_at") @db.Timestamptz
  completedAt    DateTime? @map("completed_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  content        ContentItem?  @relation(fields: [contentId], references: [id], onDelete: SetNull)

  @@index([status, priority])
  @@index([jobType])
  @@index([status, jobType])
  @@map("workflow_jobs")
}

