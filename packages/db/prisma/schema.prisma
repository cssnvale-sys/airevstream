model AssetRegistryEntry {
  id            String   @id @default(uuid()) @db.Uuid
  type          String   @db.VarChar(20) // image, video, audio, model, lora, workflow
  storageKey    String   @map("storage_key")
  hash          String?  @db.VarChar(128)
  fileSize      Int?     @map("file_size")
  mimeType      String?  @map("mime_type") @db.VarChar(100)
  version       Int      @default(1)
  parentAssetId String?  @map("parent_asset_id") @db.Uuid
  generatedBy   String?  @map("generated_by") @db.VarChar(50) // comfyui, remotion, tts, manual
  provenance    Json     @default("{}") @db.JsonB
  contentId     String?  @map("content_id") @db.Uuid
  shotId        String?  @map("shot_id") @db.Uuid
  sequenceId    String?  @map("sequence_id") @db.Uuid
  metadata      Json     @default("{}") @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  content       ContentItem?       @relation(fields: [contentId], references: [id], onDelete: SetNull)
  shot          StoryboardShot?    @relation(fields: [shotId], references: [id], onDelete: SetNull)
  sequence      Sequence?          @relation(fields: [sequenceId], references: [id], onDelete: SetNull)
  parentAsset   AssetRegistryEntry? @relation("AssetVersions", fields: [parentAssetId], references: [id], onDelete: SetNull)
  childAssets   AssetRegistryEntry[] @relation("AssetVersions")

  @@index([contentId])
  @@index([shotId])
  @@index([type])
  @@index([storageKey])
  @@map("asset_registry_entries")
}

model Sequence {
  id          String   @id @default(uuid()) @db.Uuid
  channelId   String   @map("channel_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String?
  status      String   @default("draft") @db.VarChar(20) // draft, active, archived
