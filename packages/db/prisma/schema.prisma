generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// OPERATOR / AUTH
// ============================================================

model Tenant {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(255)
  slug         String   @unique @db.VarChar(100)
  plan         String   @default("free") @db.VarChar(30) // free, starter, pro, enterprise
  status       String   @default("active") @db.VarChar(20) // active, suspended, cancelled
  settings     Json     @default("{}") @db.JsonB
  limits       Json     @default("{}") @db.JsonB // { maxAccounts, maxChannels, maxContentPerMonth, storageGb }
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  users              User[]
  emailAccounts      EmailAccount[]
  subscriptions      Subscription[]
  apiKeys            ApiKey[]
  seasoningCohorts   SeasoningCohort[]
  alerts             Alert[]
  conversations      Conversation[]
  knowledgeBaseEntries KnowledgeBaseEntry[]
  promptTemplates    PromptTemplate[]
  costBudgets        CostBudget[]
  userPresets        UserPreset[]
  experiments        Experiment[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  avatarUrl    String?  @map("avatar_url")
  role         String   @default("operator") @db.VarChar(20) // admin, operator, viewer
  tenantId     String?  @map("tenant_id") @db.Uuid
  passwordChangedAt DateTime? @map("password_changed_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  refreshTokens RefreshToken[]
  userPresets   UserPreset[]

  @@index([tenantId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================
// ACCOUNTS & CHANNELS
// ============================================================

model EmailAccount {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique @db.VarChar(255)
  passwordEnc String   @map("password_enc") // AES-256-GCM encrypted
  status      String   @default("pending") @db.VarChar(20) // active, disabled, flagged, pending
  tier        String   @default("tier2") @db.VarChar(10) // tier1, tier2, tier3
  tenantId    String?  @map("tenant_id") @db.Uuid
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  tenant               Tenant?               @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  socialAccounts       SocialAccount[]
  seasoningEnrollments SeasoningEnrollment[]

  @@index([tenantId])
  @@map("email_accounts")
}

model SocialAccount {
  id              String    @id @default(uuid()) @db.Uuid
  emailAccountId  String    @map("email_account_id") @db.Uuid
  platform        String    @db.VarChar(20) // youtube, tiktok, instagram, facebook
  platformUserId  String?   @map("platform_user_id") @db.VarChar(255)
  username        String?   @db.VarChar(255)
  credentialsEnc  String?   @map("credentials_enc") // encrypted platform tokens/cookies
  status          String    @default("pending") @db.VarChar(20) // active, disabled, flagged, pending, needs_signup
  healthScore     Int       @default(100) @map("health_score")
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz
  lastPostAt      DateTime? @map("last_post_at") @db.Timestamptz
  metadata        Json      @default("{}") @db.JsonB
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  emailAccount         EmailAccount          @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
  channels             Channel[]
  postings             ScheduledPost[]
  seasoningEnrollments SeasoningEnrollment[]

  @@unique([emailAccountId, platform])
  @@index([emailAccountId])
  @@index([platform])
  @@map("social_accounts")
}

model Channel {
  id                String   @id @default(uuid()) @db.Uuid
  socialAccountId   String   @map("social_account_id") @db.Uuid
  name              String   @db.VarChar(255)
  platformChannelId String?  @map("platform_channel_id") @db.VarChar(255)
  primaryLanguage   String   @default("en") @map("primary_language") @db.VarChar(10)
  familyId          String?  @map("family_id") @db.Uuid

  // Identity Profile
  niches          String[]  @default([])
  tone            String?   @db.VarChar(50) // comedic, educational, professional, etc.
  personality     String?
  targetAudience  String?   @map("target_audience")
  postingCadence  Json      @default("{}") @map("posting_cadence") @db.JsonB

  // Asset References
  cinemaBibleId   String?   @map("cinema_bible_id") @db.Uuid

  // Platform-Specific
  platformMetadata Json     @default("{}") @map("platform_metadata") @db.JsonB

  // Status
  status          String    @default("active") @db.VarChar(20)
  healthScore     Int       @default(100) @map("health_score")
  isPrimary       Boolean   @default(false) @map("is_primary")

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  socialAccount      SocialAccount        @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  channelAvatars     ChannelAvatar[]
  brandingPackages   BrandingPackage[]
  channelScenery     ChannelScenery[]
  cinemaBibles       CinemaBible[]
  contentItems       ContentItem[]
  scheduledPosts     ScheduledPost[]
  storefronts        Storefront[]
  affiliatePool      ChannelAffiliatePool[]
  affiliateClicks    AffiliateClick[]
  aiServiceUsage     AiServiceUsage[]
  sequences          Sequence[]

  @@index([socialAccountId])
  @@index([familyId])
  @@map("channels")
}

// ============================================================
// ASSETS: AVATARS, BRANDING, SCENERY, VOICES
// ============================================================

model Avatar {
  id                String   @id @default(uuid()) @db.Uuid
  name              String   @db.VarChar(255)

  // Physical Description
  description       Json     @db.JsonB // { physical: {}, mental: {}, emotional: {} }
  traitLock         Json     @default("{}") @map("trait_lock") @db.JsonB

  // Images (multi-angle)
  images            Json     @default("{}") @db.JsonB // { face, waist, body_front, body_back }

  // Voice
  voiceProfiles     Json     @default("{}") @map("voice_profiles") @db.JsonB

  // Generation History
  generationHistory Json     @default("[]") @map("generation_history") @db.JsonB

  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  channelAvatars    ChannelAvatar[]

  @@map("avatars")
}

model ChannelAvatar {
  channelId String  @map("channel_id") @db.Uuid
  avatarId  String  @map("avatar_id") @db.Uuid
  isPrimary Boolean @default(false) @map("is_primary")
  role      String? @db.VarChar(50) // main_character, supporting, narrator

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  avatar  Avatar  @relation(fields: [avatarId], references: [id], onDelete: Cascade)

  @@id([channelId, avatarId])
  @@map("channel_avatars")
}

model BrandingPackage {
  id         String   @id @default(uuid()) @db.Uuid
  channelId  String   @map("channel_id") @db.Uuid
  logoUrl    String?  @map("logo_url")
  bannerUrl  String?  @map("banner_url")
  colors     Json     @default("{}") @db.JsonB // { primary, secondary, accent }
  fonts      Json     @default("{}") @db.JsonB // { heading, body }
  templates  Json     @default("[]") @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@map("branding_packages")
}

model SceneryAsset {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  category  String?  @db.VarChar(50) // city, nature, studio, fantasy
  imageUrl  String   @map("image_url")
  prompt    String?
  metadata  Json     @default("{}") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  channelScenery ChannelScenery[]

  @@map("scenery_assets")
}

model ChannelScenery {
  channelId  String @map("channel_id") @db.Uuid
  sceneryId  String @map("scenery_id") @db.Uuid

  channel Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  scenery SceneryAsset @relation(fields: [sceneryId], references: [id], onDelete: Cascade)

  @@id([channelId, sceneryId])
  @@map("channel_scenery")
}

// ============================================================
// CINEMA BIBLES
// ============================================================

model CinemaBible {
  id               String   @id @default(uuid()) @db.Uuid
  channelId        String   @map("channel_id") @db.Uuid
  version          Int      @default(1)

  lookBible        Json     @default("{}") @map("look_bible") @db.JsonB
  characterBible   Json     @default("{}") @map("character_bible") @db.JsonB
  environmentBible Json     @default("{}") @map("environment_bible") @db.JsonB
  promptBible      Json     @default("{}") @map("prompt_bible") @db.JsonB
  shotspecTemplate  Json     @default("{}") @map("shotspec_template") @db.JsonB

  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, version])
  @@map("cinema_bibles")
}

// ============================================================
// AI SERVICE REGISTRY
// ============================================================

model AiService {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(100) // "openai-gpt4", "ollama-llama3", "veo3"
  provider       String   @db.VarChar(50)  // openai, anthropic, google, ollama, comfyui
  serviceType    String   @map("service_type") @db.VarChar(20) // text, image, video, voice
  endpoint       String?
  apiKeyEnc      String?  @map("api_key_enc") // encrypted

  // Capabilities
  capabilities   Json     @default("{}") @db.JsonB
  rateLimits     Json     @default("{}") @map("rate_limits") @db.JsonB
  costPerUnit    Json     @default("{}") @map("cost_per_unit") @db.JsonB

  // Status
  status         String   @default("active") @db.VarChar(20) // active, degraded, down, disabled
  healthScore    Int      @default(100) @map("health_score")
  lastHealthCheck DateTime? @map("last_health_check") @db.Timestamptz

  // Performance
  avgResponseMs  Int?     @map("avg_response_ms")
  successRate    Decimal  @default(1.0) @map("success_rate") @db.Decimal(5, 4)
  avgQualityScore Decimal? @map("avg_quality_score") @db.Decimal(3, 1)

  // Fallback
  fallbackOrder  Int      @default(0) @map("fallback_order")
  fallbackGroup  String?  @map("fallback_group") @db.VarChar(50)

  isLocal        Boolean  @default(false) @map("is_local")
  isFree         Boolean  @default(false) @map("is_free")

  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  usage          AiServiceUsage[]
  contentItems   ContentItem[]
  storyboardShots StoryboardShot[]

  @@index([serviceType])
  @@index([fallbackGroup, fallbackOrder])
  @@map("ai_services")
}

model AiServiceUsage {
  id           String   @id @default(uuid()) @db.Uuid
  serviceId    String   @map("service_id") @db.Uuid
  contentId    String?  @map("content_id") @db.Uuid
  channelId    String?  @map("channel_id") @db.Uuid

  requestType  String?  @map("request_type") @db.VarChar(50)
  tokensUsed   Int?     @map("tokens_used")
  durationSec  Decimal? @map("duration_sec") @db.Decimal(8, 2)
  cost         Decimal? @db.Decimal(10, 4)
  qualityScore Decimal? @map("quality_score") @db.Decimal(3, 1)
  success      Boolean  @default(true)
  responseMs   Int?     @map("response_ms")
  errorMessage String?  @map("error_message")

  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  service AiService    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  content ContentItem? @relation(fields: [contentId], references: [id], onDelete: SetNull)
  channel Channel?     @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([serviceId])
  @@index([createdAt])
  @@map("ai_service_usage")
}

// ============================================================
// CONTENT
// ============================================================

model ContentItem {
  id              String   @id @default(uuid()) @db.Uuid
  channelId       String   @map("channel_id") @db.Uuid

  // Content Identity
  title           String?  @db.VarChar(500)
  contentType     String   @map("content_type") @db.VarChar(30) // text, image, video_short, video_long, voice, thumbnail
  contentPurpose  String?  @map("content_purpose") @db.VarChar(30) // entertainment, sales, educational, comedy, affiliate

  // Generation
  prompt          String?
  generationParams Json    @default("{}") @map("generation_params") @db.JsonB
  aiServiceId     String?  @map("ai_service_id") @db.Uuid
  qualityScore    Decimal? @map("quality_score") @db.Decimal(3, 1)

  // Files
  fileUrl         String?  @map("file_url")
  thumbnailUrl    String?  @map("thumbnail_url")

  // Metadata
  platformMetadata Json    @default("{}") @map("platform_metadata") @db.JsonB
  beatTags        Json     @default("[]") @map("beat_tags") @db.JsonB
  durationSec     Decimal? @map("duration_sec") @db.Decimal(8, 2)
  language        String   @default("en") @db.VarChar(10)

  // Affiliate
  affiliateProductId String? @map("affiliate_product_id") @db.Uuid
  affiliateMode   String?  @map("affiliate_mode") @db.VarChar(20) // dedicated, commercial_break, none

  // Versioning
  version         Int      @default(1)
  parentId        String?  @map("parent_id") @db.Uuid

  // Language variants
  languageFamilyId String? @map("language_family_id") @db.Uuid

  // Status
  status          String   @default("draft") @db.VarChar(20) // draft, generating, generated, pending_approval, approved, scheduled, posted, archived, failed

  // Approval
  approvalGateWindowHrs Decimal? @map("approval_gate_window_hrs") @db.Decimal(5, 1)
  approvedAt      DateTime? @map("approved_at") @db.Timestamptz
  approvedBy      String?  @map("approved_by") @db.VarChar(50) // operator, auto, system

  // Performance
  performance     Json     @default("{}") @db.JsonB

  // Provenance
  provenance      Json     @default("{}") @db.JsonB

  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  channel         Channel          @relation(fields: [channelId], references: [id])
  aiService       AiService?       @relation(fields: [aiServiceId], references: [id], onDelete: SetNull)
  affiliateProduct AffiliateProduct? @relation(fields: [affiliateProductId], references: [id], onDelete: SetNull)
  parent          ContentItem?     @relation("ContentVersions", fields: [parentId], references: [id], onDelete: SetNull)
  children        ContentItem[]    @relation("ContentVersions")
  storyboards     Storyboard[]
  scheduledPosts  ScheduledPost[]
  aiServiceUsage  AiServiceUsage[]
  affiliateClicks AffiliateClick[]
  workflowJobs    WorkflowJob[]
  assetRegistryEntries AssetRegistryEntry[]
  sequenceItems   SequenceItem[]
  experimentVariants ExperimentVariant[]

  @@index([channelId])
  @@index([status])
  @@index([contentType])
  @@index([languageFamilyId])
  @@map("content_items")
}

// ============================================================
// VIDEO PRODUCTION
// ============================================================

model Storyboard {
  id              String   @id @default(uuid()) @db.Uuid
  contentId       String   @map("content_id") @db.Uuid
  status          String   @default("draft") @db.VarChar(20) // draft, approved, in_production
  scriptJson      Json     @map("script_json") @db.JsonB
  soundPlanJson   Json?    @map("sound_plan_json") @db.JsonB
  totalDurationSec Decimal? @map("total_duration_sec") @db.Decimal(8, 2)
  fps             Int      @default(24)
  aspectRatio     String   @default("16:9") @map("aspect_ratio") @db.VarChar(10)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  content ContentItem     @relation(fields: [contentId], references: [id], onDelete: Cascade)
  shots   StoryboardShot[]

  @@index([contentId])
  @@map("storyboards")
}

model StoryboardShot {
  id            String   @id @default(uuid()) @db.Uuid
  storyboardId  String   @map("storyboard_id") @db.Uuid
  shotNumber    Int      @map("shot_number")

  // ShotSpec
  shotspec      Json     @db.JsonB

  // Generated Assets
  keyframeUrls  Json     @default("[]") @map("keyframe_urls") @db.JsonB
  plateVideoUrl String?  @map("plate_video_url")
  matteUrls     Json     @default("[]") @map("matte_urls") @db.JsonB
  audioStemUrls Json     @default("{}") @map("audio_stem_urls") @db.JsonB

  // Status
  status        String   @default("pending") @db.VarChar(20) // pending, generating, generated, approved, failed
  qualityScore  Decimal? @map("quality_score") @db.Decimal(3, 1)
  generationCost Decimal? @map("generation_cost") @db.Decimal(10, 4)
  aiServiceId   String?  @map("ai_service_id") @db.Uuid

  // Timing
  startSec      Decimal  @map("start_sec") @db.Decimal(8, 2)
  endSec        Decimal  @map("end_sec") @db.Decimal(8, 2)

  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  storyboard Storyboard @relation(fields: [storyboardId], references: [id], onDelete: Cascade)
  aiService  AiService? @relation(fields: [aiServiceId], references: [id], onDelete: SetNull)
  assetRegistryEntries AssetRegistryEntry[]

  @@index([storyboardId, shotNumber])
  @@map("storyboard_shots")
}

// ============================================================
// SCHEDULING & DISTRIBUTION
// ============================================================

model ScheduledPost {
  id              String   @id @default(uuid()) @db.Uuid
  contentId       String   @map("content_id") @db.Uuid
  channelId       String   @map("channel_id") @db.Uuid

  scheduledAt     DateTime @map("scheduled_at") @db.Timestamptz
  platform        String   @db.VarChar(20)

  // Platform-specific publish data
  publishConfig   Json     @default("{}") @map("publish_config") @db.JsonB

  // Status
  status          String   @default("scheduled") @db.VarChar(20) // scheduled, posting, posted, failed, cancelled
  postedAt        DateTime? @map("posted_at") @db.Timestamptz
  platformPostId  String?  @map("platform_post_id") @db.VarChar(255)
  errorMessage    String?  @map("error_message")
  retryCount      Int      @default(0) @map("retry_count")

  // Account used for posting
  socialAccountId String?  @map("social_account_id") @db.Uuid

  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  content       ContentItem    @relation(fields: [contentId], references: [id])
  channel       Channel        @relation(fields: [channelId], references: [id])
  socialAccount SocialAccount? @relation(fields: [socialAccountId], references: [id], onDelete: SetNull)

  @@index([channelId, scheduledAt])
  @@index([status, scheduledAt])
  @@map("scheduled_posts")
}

// ============================================================
// AFFILIATE MARKETING
// ============================================================

model AffiliateProduct {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(255)
  url             String
  shortUrl        String?  @map("short_url")
  description     String?
  salesAngle      String?  @map("sales_angle")
  category        String?  @db.VarChar(100)
  brand           String?  @db.VarChar(100)
  commissionRate  Decimal? @map("commission_rate") @db.Decimal(5, 2)
  status          String   @default("active") @db.VarChar(20) // active, inactive, expired
  imageUrl        String?  @map("image_url")
  metadata        Json     @default("{}") @db.JsonB

  // Performance
  totalClicks     Int      @default(0) @map("total_clicks")
  totalConversions Int     @default(0) @map("total_conversions")
  totalRevenue    Decimal  @default(0) @map("total_revenue") @db.Decimal(12, 2)

  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  channelPools       ChannelAffiliatePool[]
  clicks             AffiliateClick[]
  contentItems       ContentItem[]
  storefrontProducts StorefrontProduct[]

  @@index([status])
  @@map("affiliate_products")
}

model ChannelAffiliatePool {
  channelId          String   @map("channel_id") @db.Uuid
  affiliateProductId String   @map("affiliate_product_id") @db.Uuid
  isAutoSuggested    Boolean  @default(false) @map("is_auto_suggested")
  performanceScore   Decimal  @default(0) @map("performance_score") @db.Decimal(5, 2)
  lastUsedAt         DateTime? @map("last_used_at") @db.Timestamptz

  channel          Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  affiliateProduct AffiliateProduct @relation(fields: [affiliateProductId], references: [id], onDelete: Cascade)

  @@id([channelId, affiliateProductId])
  @@map("channel_affiliate_pools")
}

model AffiliateClick {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  contentId  String?  @map("content_id") @db.Uuid
  channelId  String?  @map("channel_id") @db.Uuid
  platform   String?  @db.VarChar(20)
  ipHash     String?  @map("ip_hash") @db.VarChar(64)
  userAgent  String?  @map("user_agent")
  converted  Boolean  @default(false)
  revenue    Decimal? @db.Decimal(10, 2)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  product AffiliateProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  content ContentItem?     @relation(fields: [contentId], references: [id], onDelete: SetNull)
  channel Channel?         @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
  @@map("affiliate_clicks")
}

// ============================================================
// APPROVAL GATES & TRUST
// ============================================================

model ApprovalTrustScore {
  id              String   @id @default(uuid()) @db.Uuid
  dimensionType   String   @map("dimension_type") @db.VarChar(30) // content_type, llm, workflow, tier, niche, platform
  dimensionValue  String   @map("dimension_value") @db.VarChar(100)

  trustScore      Decimal  @default(0) @map("trust_score") @db.Decimal(5, 2) // 0-100
  gateWindowHrs   Decimal  @default(24) @map("gate_window_hrs") @db.Decimal(5, 1)

  totalApproved       Int  @default(0) @map("total_approved")
  totalRejected       Int  @default(0) @map("total_rejected")
  totalAutoApproved   Int  @default(0) @map("total_auto_approved")
  avgOutcomeScore     Decimal @default(0) @map("avg_outcome_score") @db.Decimal(5, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([dimensionType, dimensionValue])
  @@map("approval_trust_scores")
}

