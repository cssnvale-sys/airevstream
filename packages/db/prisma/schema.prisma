  socialAccountId     String?   @map("social_account_id") @db.Uuid
  platform            String    @db.VarChar(20)
  status              String    @default("pending") @db.VarChar(20) // pending, signing_up, needs_human, phase_1..4, seasoned, failed, graduated, paused
  currentPhase        String?   @map("current_phase") @db.VarChar(20)
  phaseStartedAt      DateTime? @map("phase_started_at") @db.Timestamptz
  proxyServer         String?   @map("proxy_server") @db.VarChar(255)
