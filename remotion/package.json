{
  "name": "@airevstream/remotion",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "studio": "remotion studio src/Root.tsx",
    "render": "remotion render src/Root.tsx",
    "render:short": "remotion render src/Root.tsx ShortFormVideo --output=out/short.mp4",
    "render:long": "remotion render src/Root.tsx LongFormVideo --output=out/long.mp4",
    "render:thumbnail": "remotion still src/Root.tsx ThumbnailRenderer --output=out/thumbnail.png",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "remotion": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/player": "^4.0.0",
    "@remotion/media-utils": "^4.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0"
  }
}
